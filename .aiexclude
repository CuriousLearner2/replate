venv/
node_modules/
replate-business-env/

# Python Cache & Bytecode
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Testing & Tools
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Git & Local Config
.git/
.env
.replate/
session.json

# Tool-specific outputs
replate/replate/
